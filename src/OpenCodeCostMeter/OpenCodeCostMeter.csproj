<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\icon.ico</ApplicationIcon>
    <AssemblyTitle>OpenCode Cost Meter</AssemblyTitle>
    <AssemblyProduct>OpenCode Cost Meter</AssemblyProduct>
    <NoWarn>$(NoWarn);NU1903</NoWarn>
    <DebugType>embedded</DebugType>
    <!-- Avalonia 12 enables compiled bindings by default; keep v11 reflection
         behavior since no x:DataType is set anywhere. -->
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\icon.ico" />
    <None Include="Assets\generate-icon.py" />
    <None Include="Assets\icon.svg" />
    <None Update="model-display-names.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" Version="12.1.0" />
    <PackageReference Include="Avalonia.Themes.Simple" Version="12.1.0" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.1.0" />
    <PackageReference Include="Fonts.Avalonia.CascadiaCode" Version="0.14.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OpenCodeCostMeter.Core\OpenCodeCostMeter.Core.csproj" />
  </ItemGroup>

</Project>
