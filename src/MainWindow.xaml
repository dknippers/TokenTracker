<Window x:Class="OpenCodeCostMeter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OpenCodeCostMeter.Converters"
        xmlns:vm="clr-namespace:OpenCodeCostMeter.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="OpenCode Cost Meter"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">
    <Window.Resources>
        <SolidColorBrush x:Key="MicaBg" Color="#20201F"/>
        <SolidColorBrush x:Key="MicaStroke" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="OnSurface" Color="#E5E2E1"/>
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#ADABAA"/>
        <SolidColorBrush x:Key="Secondary" Color="#61DBB4"/>
        <SolidColorBrush x:Key="RowHover" Color="#2A2A2A"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToCollapsed" TrueVisibility="Collapsed" FalseVisibility="Visible"/>
        <conv:BoolToBrushConverter x:Key="AmountHighlightBrush" TrueBrush="{StaticResource Secondary}" FalseBrush="{StaticResource OnSurface}"/>
        <conv:BoolToBrushConverter x:Key="ModelCostHighlightBrush" TrueBrush="{StaticResource Secondary}" FalseBrush="{StaticResource OnSurfaceVariant}"/>
        <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>
        <Style TargetType="Border">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style x:Key="CardMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
            <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="4,8,0,8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid Margin="0">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="0" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Check" Grid.Column="0" Text="&#x2713;" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource Secondary}" VerticalAlignment="Center" TextAlignment="Center"
                                               Visibility="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu" BasedOn="{StaticResource {x:Type ContextMenu}}">
            <Setter Property="Background" Value="{StaticResource MicaBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MicaStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0" Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="4"
            Background="{StaticResource MicaBg}"
            BorderBrush="{StaticResource MicaStroke}"
            BorderThickness="1"
            MouseLeftButtonDown="OnCardMouseLeftButtonDown"
            MouseRightButtonUp="OnCardMouseRightButtonUp">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Padding" Value="16,8"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Padding" Value="20,12"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.ContextMenu>
            <ContextMenu/>
        </Border.ContextMenu>
        
        <StackPanel>
            <!-- Normal content (hidden on error) -->
            <StackPanel Visibility="{Binding HasError, Converter={StaticResource BoolToCollapsed}}">
                <!-- Primary Spend Card -->
                <TextBlock Text="{Binding TodayCostText}" FontFamily="{StaticResource MonoFont}" FontSize="26" FontWeight="Bold"
                               Foreground="{Binding IsTodayCostHighlighted, Converter={StaticResource AmountHighlightBrush}}"
                               HorizontalAlignment="Center"/>

                <TextBlock Text="no usage yet" FontFamily="{StaticResource MonoFont}" FontSize="14"
                           Foreground="{StaticResource OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,12,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                        <Condition Binding="{Binding HasModels}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel Visibility="{Binding HasModels, Converter={StaticResource BoolToVis}}">
                    <!-- Breakdown List -->
                    <Border ClipToBounds="True" MaxHeight="320" Margin="0,4"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Width" Value="5"/>
                                    <Setter Property="Margin" Value="16,10,0,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsEnabled}">
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{StaticResource OnSurface}" CornerRadius="2"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ScrollViewer.Resources>
                            <ItemsControl ItemsSource="{Binding ModelRows}" FocusVisualStyle="{x:Null}" Focusable="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ModelRowViewModel}">
                                        <Border CornerRadius="0" Margin="0,12,0,0" Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource RowHover}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Header}" FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Medium"
                                                           Foreground="{StaticResource OnSurface}" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CostText}" FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Medium"
                                                           Foreground="{Binding IsCostHighlighted, Converter={StaticResource ModelCostHighlightBrush}}" VerticalAlignment="Bottom"
                                                           HorizontalAlignment="Right" Margin="16,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Error text (shown only on error) -->
            <StackPanel Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorText}" FontFamily="{StaticResource MonoFont}" FontSize="14" Foreground="#E0B341"
                               MaxWidth="360" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>